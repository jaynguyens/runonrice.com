{
  "name": "runonrice",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:www": "bun --filter www dev",
    "dev:membo": "bun --filter membo dev",
    "build:www": "bun --filter www build",
    "build:membo": "bun --filter membo build",
    "build": "bun run --filter '*' build",
    "deploy:www": "bun --filter www deploy",
    "deploy:membo": "bun --filter membo deploy"
  },
  "devDependencies": {
    "wrangler": "^4.82.2"
  }
}
